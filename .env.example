# Environment Variables for AskSUSSi

# Google Gemini API key for AI chat
GOOGLE_GENERATIVE_AI_API_KEY=

# Google Maps API key (browser-side, for Maps 3D and client features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Maps API key (server-side, for Routes API)
GOOGLE_MAPS_API_KEY=

# Google Cloud Speech-to-Text credentials (JSON service account key)
GOOGLE_CLOUD_STT_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
# Or use a file path instead:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
